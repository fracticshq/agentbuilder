# Agent Builder Platform - Root Configuration Example
# Copy this file to .env and replace with your actual values

# =============================================================================
# Azure Key Vault Configuration (Primary Source for Secrets)
# =============================================================================

# Set to true to fetch secrets from Azure Key Vault at runtime
USE_AZURE_KEYVAULT=true
AZURE_KEYVAULT_NAME=kv-agentbuilder-dev

# -----------------------------------------------------------------------------
# Authentication: Choose ONE method
# -----------------------------------------------------------------------------
# Option 1: Local Development (Login via CLI)
# Just run: az login

# Option 2: Service Principal (CI/CD or Docker)
# AZURE_CLIENT_ID=your-service-principal-client-id
# AZURE_CLIENT_SECRET=your-service-principal-secret
# AZURE_TENANT_ID=your-azure-tenant-id

# =============================================================================
# Global Configuration (Non-Sensitive)
# =============================================================================

# Environment (development | staging | production)
NODE_ENV=development
ENVIRONMENT=development

# Application name
APP_NAME=nova

# =============================================================================
# Application URLs & Ports
# =============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000

# Widget App
WIDGET_URL=http://localhost:5174

# Admin Dashboard
ADMIN_URL=http://localhost:3000

# =============================================================================
# Logging & Monitoring (Non-Sensitive)
# =============================================================================

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable features
ENABLE_WEBSOCKETS=true
ENABLE_SSE=true
ENABLE_METRICS=true
ENABLE_TRACING=false
ENABLE_HUMAN_TAKEOVER=true

# =============================================================================
# Rate Limiting
# =============================================================================

RATE_LIMIT_FAIL_CLOSED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_POLICY_WIDGET_CHAT=60
RATE_LIMIT_POLICY_WIDGET_STREAM=40
RATE_LIMIT_POLICY_WIDGET_WS_CONNECT=30
RATE_LIMIT_POLICY_WIDGET_WS_MESSAGE=120
RATE_LIMIT_POLICY_ADMIN_API=300
RATE_LIMIT_POLICY_UPLOAD=20
RATE_LIMIT_POLICY_STRAPI_SYNC=600

# =============================================================================
# Secrets Registry (These should be moved to Azure Key Vault)
# =============================================================================
# The following keys are fetched from AKV if USE_AZURE_KEYVAULT is true.
# If NOT using AKV, you can define them here for local development.

# MONGODB_URI=mongodb+srv://...
# REDIS_URL=rediss://...
# VECTOR_BACKEND=atlas
# VECTOR_INDEX_NAME=vector_index
# VECTOR_DIMENSIONS=1024
# ATLAS_PROJECT_ID=
# ATLAS_CLUSTER_NAME=
# ATLAS_PUBLIC_KEY=
# ATLAS_PRIVATE_KEY=
# ATLAS_AUTO_CREATE_VECTOR_INDEXES=false
# QDRANT_URL=http://localhost:6333
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=...
# AZURE_OPENAI_API_VERSION=...
# AZURE_OPENAI_DEPLOYMENT=...
# VOYAGE_API_KEY=pa-...
# VOYAGE_BASE_URL=https://api.voyageai.com/v1
# SECRET_KEY=...
# SETTINGS_ENCRYPTION_KEY=...
# PII_ENCRYPTION_KEY=...
# ADMIN_API_KEY=...
# MCP_SERVICE_AUTH_TOKEN=...  # Internal API <-> Shopify MCP shared credential
# SESSION_SECRET=...          # Shopify MCP OAuth session secret
# QWEN_API_KEY=...
# STRAPI_URL=https://agentbuilder-strapi.example.com
# STRAPI_API_TOKEN=...
# AGENTBUILDER_ADMIN_API_KEY should match ADMIN_API_KEY in Strapi deployments.
# FIRECRAWL_API_KEY=...
# Shopify store domains and store access tokens are per-agent dashboard
# configuration, not root/container environment variables.
