# Agent Builder Platform - Root Configuration Example
# Copy this file to .env and replace with your actual values
# This file contains shared configuration for all applications

# =============================================================================
# Global Configuration
# =============================================================================

# Environment (development | staging | production)
NODE_ENV=development
ENVIRONMENT=development

# =============================================================================
# MongoDB Configuration (Shared)
# =============================================================================

# MongoDB Atlas Connection
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/?retryWrites=true&w=majority&appName=agent-builder
MONGODB_DATABASE=agent-builder

# =============================================================================
# Redis Configuration (Shared)
# =============================================================================

# Redis Connection
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SSL=false

# =============================================================================
# API Keys (Shared)
# =============================================================================

# OpenAI API Key
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Voyage AI Embeddings Key
VOYAGE_API_KEY=pa-your-voyage-api-key-here

# =============================================================================
# Security (Shared)
# =============================================================================

# Secret keys for JWT and encryption
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-key-change-in-production

# PII Encryption Key (32-byte base64)
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=your-32-byte-base64-encoded-encryption-key-here

# =============================================================================
# Application URLs
# =============================================================================

# API Server
API_URL=http://localhost:8000

# Widget App
WIDGET_URL=http://localhost:5173

# Admin Dashboard
ADMIN_URL=http://localhost:3000

# =============================================================================
# Logging & Monitoring
# =============================================================================

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Development Tools
# =============================================================================

# Enable hot reload
HOT_RELOAD=true

# Debug mode
DEBUG=true
