# ─────────────────────────────────────────────────────────────────────────────
# Agent Builder — Docker Environment Template
#
# 1. Copy this file:  cp .env.docker.example .env.docker
# 2. Fill in the values below
# 3. Run:             docker compose up --build
#
# NOTE: Never commit your real .env file — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime provider bootstrap ───────────────────────────────────────────────
# These values can now be managed from Admin -> Settings after the stack is up.
# Keep them here as bootstrap/fallback values until you have saved them in the dashboard.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI inference (required when DEFAULT_LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=

# Azure ARM discovery (required for the admin dashboard deployment picker)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_OPENAI_ACCOUNT_NAME=

# ── Required: Embeddings ───────────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...
VOYAGE_BASE_URL=https://api.voyageai.com/v1
VOYAGE_MODEL=voyage-3-large
VOYAGE_RERANK_MODEL=rerank-2.5

# ── Required: Security ────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-string
PII_ENCRYPTION_KEY=change-me-to-a-random-32-char-string
SETTINGS_ENCRYPTION_KEY=change-me-to-a-random-32-char-string
ADMIN_API_KEY=change-me-to-a-random-32-char-string
# Shared with the Shopify MCP container. Generate a distinct high-entropy value.
MCP_SERVICE_AUTH_TOKEN=change-me-to-a-different-random-32-char-string
# Used only by the Shopify MCP container for its Redis-backed OAuth session.
SESSION_SECRET=change-me-to-a-different-random-32-char-string
# Shopify catalog webhooks are disabled by default. When this stack is the
# Shopify webhook target, enable them and set the Shopify app's signing secret.
SHOPIFY_WEBHOOKS_ENABLED=false
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_WEBHOOK_MAX_BODY_BYTES=1048576
SHOPIFY_ADMIN_API_VERSION=2026-04
# Override only if the Shopify MCP bridge must forward to a non-default API URL.
SHOPIFY_WEBHOOK_FORWARD_URL=http://api:8000/api/v1/catalog/shopify/webhooks
ADMIN_APP_URL=http://localhost:3000
ALLOW_PUBLIC_SIGNUP=false
GOOGLE_CLIENT_ID=

# ── Databases (set automatically by docker-compose — leave as-is) ─────────────
# These are overridden in docker-compose.yml to use container names.
# Only change if you're connecting to external hosted databases.
MONGODB_URI=mongodb://mongodb:27017
REDIS_URL=redis://redis:6379
MONGO_SYSTEM_DB=system
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
# Required by the internal Qdrant service. Replace before any shared deployment.
QDRANT_API_KEY=change-me-to-a-different-random-32-char-string
QDRANT_COLLECTION_PREFIX=nova
VECTOR_DIMENSIONS=1024

# Use these only when VECTOR_BACKEND=atlas and you want bootstrap to manage Atlas
# Vector Search indexes through the Atlas Admin API.
VECTOR_INDEX_NAME=vector_index
ATLAS_PROJECT_ID=
ATLAS_CLUSTER_NAME=
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_AUTO_CREATE_VECTOR_INDEXES=false

# ── Optional: Firecrawl (product catalog scraping) ────────────────────────────
FIRECRAWL_API_KEY=fc-...

# ── Optional: Qwen (alternative LLM) ─────────────────────────────────────────
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# ── Optional: Azure Key Vault (leave false for local Docker use) ──────────────
USE_AZURE_KEYVAULT=false
AZURE_KEYVAULT_NAME=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── App config (defaults are fine for local Docker) ───────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENABLE_WEBSOCKETS=true
ENABLE_SSE=true
ENABLE_METRICS=true
ENABLE_TRACING=false
RATE_LIMIT_FAIL_CLOSED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_POLICY_WIDGET_CHAT=60
RATE_LIMIT_POLICY_WIDGET_STREAM=40
RATE_LIMIT_POLICY_WIDGET_WS_CONNECT=30
RATE_LIMIT_POLICY_WIDGET_WS_MESSAGE=120
RATE_LIMIT_POLICY_ADMIN_API=300
RATE_LIMIT_POLICY_UPLOAD=20
RATE_LIMIT_POLICY_STRAPI_SYNC=600
MAX_FILE_SIZE_MB=10
MAX_UPLOAD_FILES=20
MAX_UPLOAD_TOTAL_SIZE_MB=50
MAX_ARCHIVE_FILES=5000
MAX_ARCHIVE_UNCOMPRESSED_SIZE_MB=100
MAX_ARCHIVE_COMPRESSION_RATIO=100
# Local Compose does not include a malware engine. Production startup requires
# MALWARE_SCAN_MODE=clamav and a private ClamAV-compatible scanner endpoint.
MALWARE_SCAN_MODE=disabled
MALWARE_SCAN_HOST=clamav
MALWARE_SCAN_PORT=3310
MALWARE_SCAN_TIMEOUT_SECONDS=15
CATALOG_SYNC_JOB_TTL_SECONDS=604800
CATALOG_SYNC_LEASE_SECONDS=180
CATALOG_SYNC_MAX_ATTEMPTS=5
CATALOG_SYNC_RETRY_DELAY_SECONDS=30
CATALOG_SYNC_WORKER_POLL_SECONDS=2
CATALOG_SYNC_SCHEDULER_POLL_SECONDS=60
DEFAULT_LLM_PROVIDER=azure_openai

# ── Optional: protected synthetic staging-quality evidence ──────────────────
# Dark by default. This never enables from ENVIRONMENT and does not call a
# model/provider. Set the protected profile allowlist only for a controlled
# staging deployment; use a separately issued Agent API key with
# evaluations:write, bound to exactly one agent and brand.
EVAL_STAGING_ENABLED=false
EVAL_STAGING_TARGET_ALLOWLIST=
EVAL_STAGING_MAX_CASES=25
EVAL_RESULT_TTL_SECONDS=604800

# ── Strapi dashboard sync ────────────────────────────────────────────────────
# STRAPI_API_TOKEN must match agentbuilder-strapi's STRAPI_API_TOKEN.
STRAPI_URL=http://host.docker.internal:1337
STRAPI_API_TOKEN=change-me-to-a-random-32-char-string

# ── Strapi privacy deletion contract ────────────────────────────────────────
# Separate from dashboard sync. contract_pending is intentionally network-off.
STRAPI_PRIVACY_MODE=contract_pending
# Set a unique, 32+ character key before using privacy subject deletion.
# STRAPI_PRIVACY_SUBJECT_HMAC_KEY=...
# The following dedicated settings are required only for STRAPI_PRIVACY_MODE=active.
# STRAPI_PRIVACY_URL=https://strapi.example.com
# STRAPI_PRIVACY_REQUEST_SIGNING_KEY=...
# STRAPI_PRIVACY_REQUEST_KEY_ID=key-2026-07
# STRAPI_PRIVACY_RECEIPT_PUBLIC_KEY=base64-encoded-ed25519-public-key
ENABLE_HUMAN_TAKEOVER=true
