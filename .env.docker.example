# ─────────────────────────────────────────────────────────────────────────────
# Agent Builder — Docker Environment Template
#
# 1. Copy this file:  cp .env.docker.example .env.docker
# 2. Fill in the values below
# 3. Run:             docker compose up --build
#
# NOTE: Never commit your real .env file — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime provider bootstrap ───────────────────────────────────────────────
# These values can now be managed from Admin -> Settings after the stack is up.
# Keep them here as bootstrap/fallback values until you have saved them in the dashboard.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI inference (required when DEFAULT_LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=

# Azure ARM discovery (required for the admin dashboard deployment picker)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_OPENAI_ACCOUNT_NAME=

# ── Required: Embeddings ───────────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-large-2-instruct

# ── Required: Security ────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-string
PII_ENCRYPTION_KEY=change-me-to-a-random-32-char-string
SETTINGS_ENCRYPTION_KEY=change-me-to-a-random-32-char-string
ADMIN_API_KEY=change-me-to-a-random-32-char-string
ADMIN_APP_URL=http://localhost:3000
ALLOW_PUBLIC_SIGNUP=false
GOOGLE_CLIENT_ID=

# ── Databases (set automatically by docker-compose — leave as-is) ─────────────
# These are overridden in docker-compose.yml to use container names.
# Only change if you're connecting to external hosted databases.
MONGODB_URI=mongodb://mongodb:27017
REDIS_URL=redis://redis:6379
MONGO_SYSTEM_DB=system

# ── Optional: Firecrawl (product catalog scraping) ────────────────────────────
FIRECRAWL_API_KEY=fc-...

# ── Optional: Qwen (alternative LLM) ─────────────────────────────────────────
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# ── Optional: Azure Key Vault (leave false for local Docker use) ──────────────
USE_AZURE_KEYVAULT=false
AZURE_KEYVAULT_NAME=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── App config (defaults are fine for local Docker) ───────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENABLE_WEBSOCKETS=true
ENABLE_SSE=true
ENABLE_METRICS=true
ENABLE_TRACING=false
RATE_LIMIT_FAIL_CLOSED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_POLICY_WIDGET_CHAT=60
RATE_LIMIT_POLICY_WIDGET_STREAM=40
RATE_LIMIT_POLICY_WIDGET_WS_CONNECT=30
RATE_LIMIT_POLICY_WIDGET_WS_MESSAGE=120
RATE_LIMIT_POLICY_ADMIN_API=300
RATE_LIMIT_POLICY_UPLOAD=20
RATE_LIMIT_POLICY_STRAPI_SYNC=600
DEFAULT_LLM_PROVIDER=azure_openai
