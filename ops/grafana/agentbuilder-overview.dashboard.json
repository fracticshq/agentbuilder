{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)", "refId": "A"}],
      "title": "API 5xx ratio (5m)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "refId": "A"}],
      "title": "API P95 latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [{"expr": "sum by (outcome) (rate(rate_limit_events_total[5m]))", "legendFormat": "{{outcome}}", "refId": "A"}],
      "title": "Rate-limit outcomes",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 4,
      "targets": [{"expr": "sum by (action, status) (increase(catalog_sync_jobs_total[1h]))", "legendFormat": "{{action}} {{status}}", "refId": "A"}],
      "title": "Shopify catalog lifecycle jobs (1h)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 5,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, action) (rate(catalog_sync_job_duration_seconds_bucket[30m])))", "legendFormat": "{{action}}", "refId": "A"}],
      "title": "Shopify catalog-sync P95 duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 6,
      "targets": [{"expr": "up{job=~\"agentbuilder-api|agentbuilder-shopify\"}", "legendFormat": "{{job}}", "refId": "A"}],
      "title": "Service scrape availability",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["agentbuilder", "production"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "Agent Builder Production Overview",
  "uid": "agentbuilder-production-overview",
  "version": 1
}
