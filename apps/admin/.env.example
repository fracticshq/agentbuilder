# Agent Builder Admin Dashboard - Configuration Example
# Copy this file to .env and replace with your actual values

# =============================================================================
# API Configuration
# =============================================================================

# API Base URL (point to your API server)
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_WS_URL=ws://localhost:8000

# =============================================================================
# Authentication Configuration
# =============================================================================

# JWT Configuration
REACT_APP_JWT_SECRET=your-jwt-secret-key-here
REACT_APP_TOKEN_EXPIRY=86400

# Session timeout (in seconds)
REACT_APP_SESSION_TIMEOUT=3600

# =============================================================================
# Admin Dashboard Configuration
# =============================================================================

# Dashboard settings
REACT_APP_DASHBOARD_TITLE=Agent Builder Admin
REACT_APP_COMPANY_NAME=Your Company Name

# Pagination
REACT_APP_DEFAULT_PAGE_SIZE=20
REACT_APP_MAX_PAGE_SIZE=100

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable admin features
REACT_APP_ENABLE_BRAND_MANAGEMENT=true
REACT_APP_ENABLE_AGENT_WIZARD=true
REACT_APP_ENABLE_KNOWLEDGE_BASE=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_USER_MANAGEMENT=true

# =============================================================================
# File Upload Configuration
# =============================================================================

# Maximum file sizes (in MB)
REACT_APP_MAX_FILE_SIZE=10
REACT_APP_MAX_BULK_UPLOAD_SIZE=50

# Allowed file types
REACT_APP_ALLOWED_FILE_TYPES=pdf,txt,md,docx,html

# =============================================================================
# Analytics & Monitoring (Optional)
# =============================================================================

# Google Analytics (optional)
REACT_APP_GA_TRACKING_ID=

# Sentry Error Tracking (optional)
REACT_APP_SENTRY_DSN=

# LogRocket Session Recording (optional)
REACT_APP_LOGROCKET_ID=

# =============================================================================
# Development Configuration
# =============================================================================

# Environment
REACT_APP_ENVIRONMENT=development

# Debug mode
REACT_APP_DEBUG=true

# Show development tools
REACT_APP_SHOW_DEV_TOOLS=true

# API request logging
REACT_APP_LOG_API_REQUESTS=true
