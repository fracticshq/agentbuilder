# Agent Builder Admin Dashboard - Configuration Example
# Copy this file to .env and replace with your actual values

# =============================================================================
# API Configuration
# =============================================================================

# API Base URL (point to your API server). Vite exposes only VITE_* variables.
# Docker runtime values (API_BASE_URL and WIDGET_BASE_URL) take precedence.
VITE_API_URL=http://localhost:8000
VITE_API_WS_URL=ws://localhost:8000

# =============================================================================
# Authentication Configuration
# =============================================================================

# Authentication is handled by the API server.
# Configure operator login, Google sign-in, and password reset in the API env:
# - SECRET_KEY
# - ADMIN_APP_URL
# - ALLOW_PUBLIC_SIGNUP
# - GOOGLE_CLIENT_ID

# =============================================================================
# Admin Dashboard Configuration
# =============================================================================

# Dashboard settings
VITE_DASHBOARD_TITLE=Agent Builder Admin
VITE_COMPANY_NAME=Your Company Name

# Pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable admin features
VITE_ENABLE_BRAND_MANAGEMENT=true
VITE_ENABLE_AGENT_WIZARD=true
VITE_ENABLE_KNOWLEDGE_BASE=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_USER_MANAGEMENT=true

# =============================================================================
# File Upload Configuration
# =============================================================================

# Maximum file sizes (in MB)
VITE_MAX_FILE_SIZE=10
VITE_MAX_BULK_UPLOAD_SIZE=50

# Allowed file types
VITE_ALLOWED_FILE_TYPES=pdf,txt,md,docx,html

# =============================================================================
# Analytics & Monitoring (Optional)
# =============================================================================

# Google Analytics (optional)
VITE_GA_TRACKING_ID=

# Sentry Error Tracking (optional)
VITE_SENTRY_DSN=

# LogRocket Session Recording (optional)
VITE_LOGROCKET_ID=

# =============================================================================
# Development Configuration
# =============================================================================

# Environment
VITE_ENVIRONMENT=development

# Debug mode
VITE_DEBUG=true

# Show development tools
VITE_SHOW_DEV_TOOLS=true

# API request logging
VITE_LOG_API_REQUESTS=true
