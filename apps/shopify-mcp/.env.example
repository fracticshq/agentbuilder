# Shopify MCP Hub - Configuration Example
# Copy this file to .env and replace with your actual values

# =============================================================================
# Server Configuration
# =============================================================================

PORT=3005
NODE_ENV=production

# =============================================================================
# Security
# =============================================================================

# Required — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-64-char-string

# Required for /mcp — shared secret used by the internal NOVA API service.
# Send it as: Authorization: Bearer <token>
MCP_SERVICE_AUTH_TOKEN=change-me-to-a-different-random-64-char-string

# Development-only escape hatch. Both values must be set exactly as below to
# allow unauthenticated /mcp calls locally; it is ignored outside development.
# NODE_ENV=development
# SHOPIFY_MCP_ALLOW_INSECURE_LOCAL_DEV=true

# =============================================================================
# Shopify OAuth application settings
# =============================================================================

SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret

# Full public URL of this service's /auth/callback route
SHOPIFY_REDIRECT_URI=https://shopify-mcp.yourdomain.com/auth/callback

# Base URL for building auth login links (used in error responses)
SHOPIFY_BASE_URL=https://shopify-mcp.yourdomain.com

# Store domains and store access tokens are not global env values.
# Configure them per brand/agent in the NOVA admin dashboard.

# Webhook signing secret — copy from Shopify Partner Dashboard → Webhooks → Signing secret
# Required for /webhooks endpoint to verify X-Shopify-Hmac-SHA256 signatures
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-signing-secret

# =============================================================================
# CORS
# =============================================================================

# Comma-separated list of allowed origins
CORS_ALLOW_ORIGINS=https://admin.yourdomain.com,https://api.yourdomain.com

# =============================================================================
# Redis (required in production for session persistence)
# =============================================================================

REDIS_URL=redis://localhost:6379
