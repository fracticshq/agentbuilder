# Agent Builder Platform - API Configuration Example
# Copy this file to .env and replace with your actual values

# =============================================================================
# LLM Provider Configuration (choose OpenAI or Azure OpenAI)
# =============================================================================

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=

# Qwen Configuration (Alternative)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Default LLM Provider (openai | azure_openai | qwen | gemini | claude)
DEFAULT_LLM_PROVIDER=openai

# =============================================================================
# Vector Database Configuration
# =============================================================================

# MongoDB Atlas Configuration
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/?retryWrites=true&w=majority&appName=agent-builder
MONGODB_DATABASE=agent-builder
MONGODB_COLLECTION=documents

# Voyage AI Embeddings
# Get your API key from: https://www.voyageai.com/
VOYAGE_API_KEY=pa-your-voyage-api-key-here
VOYAGE_MODEL=voyage-large-2-instruct

# =============================================================================
# Memory & Caching
# =============================================================================

# Redis Configuration (optional, MongoDB fallback available)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SSL=false

# =============================================================================
# Application Configuration
# =============================================================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true

# Security
# Required — generate with: openssl rand -hex 32
SECRET_KEY=

# Admin compatibility key for non-browser operator scripts.
# The dashboard itself now uses authenticated user sessions.
ADMIN_API_KEY=
ADMIN_APP_URL=http://localhost:3000
ALLOW_PUBLIC_SIGNUP=false
GOOGLE_CLIENT_ID=

# CORS Configuration (comma-separated origins)
# In production, list your actual domains:
CORS_ALLOW_ORIGINS=https://admin.yourdomain.com,https://widget.yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable features
ENABLE_WEBSOCKETS=true
ENABLE_SSE=true
ENABLE_METRICS=true
ENABLE_TRACING=false

# =============================================================================
# Rate Limiting
# =============================================================================

RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# =============================================================================
# File Upload Configuration
# =============================================================================

MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,txt,md,docx,html
UPLOAD_DIR=./uploads

# =============================================================================
# Memory System Configuration (Phase 5)
# =============================================================================

# PII Encryption (32-byte key, base64 encoded)
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=your-32-byte-base64-encoded-encryption-key-here

# Memory TTLs (in seconds)
SHORT_TERM_TTL=259200          # 72 hours
EPISODIC_TTL=7776000           # 90 days
SUMMARY_CACHE_TTL=86400        # 24 hours

# Memory Thresholds
CONFIDENCE_THRESHOLD=0.70
AUTO_SUMMARY_TURNS=4

# Memory Limits
MAX_MESSAGES_PER_CONVERSATION=1000
MAX_FACTS_PER_USER=100
MAX_SUMMARIES_PER_CONVERSATION=50

# Feature Flags
ENABLE_AUTO_SUMMARY=true
ENABLE_PII_VAULTING=true
ENABLE_FACT_EXTRACTION=true
ENABLE_GRAPH_RULES=true
ENABLE_TTL_CLEANUP=true

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379
REDIS_FALLBACK_TO_MONGO=true
REDIS_CONNECTION_TIMEOUT=5

# LLM for Summarization
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_MAX_TOKENS=150
SUMMARY_TEMPERATURE=0.3

# =============================================================================
# Development vs Production
# =============================================================================

# Environment (development | staging | production)
ENVIRONMENT=development

# Debug mode (only for development)
DEBUG=true

# =============================================================================
# Inter-Service URLs
# =============================================================================

STRAPI_URL=https://cms.yourdomain.com
STRAPI_API_TOKEN=
SHOPIFY_MCP_URL=https://shopify-mcp.yourdomain.com/mcp
FIRECRAWL_API_KEY=
