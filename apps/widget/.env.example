# Agent Builder Widget - Configuration Example
# Copy this file to .env and replace with your actual values

# =============================================================================
# API Configuration
# =============================================================================

# API Base URL (point to your API server)
VITE_API_BASE_URL=http://localhost:8000
VITE_API_WS_URL=ws://localhost:8000

# =============================================================================
# Widget Configuration
# =============================================================================

# Widget appearance
VITE_WIDGET_THEME=light
VITE_WIDGET_POSITION=bottom-right
VITE_PRIMARY_COLOR=#0066FF
VITE_SECONDARY_COLOR=#00C853

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable widget features
VITE_ENABLE_WEBSOCKETS=true
VITE_ENABLE_FILE_UPLOAD=true
VITE_ENABLE_TYPING_INDICATOR=true
VITE_ENABLE_CONVERSATION_HISTORY=true

# =============================================================================
# Analytics & Tracking (Optional)
# =============================================================================

# Google Analytics (optional)
VITE_GA_TRACKING_ID=

# Sentry Error Tracking (optional)
VITE_SENTRY_DSN=

# =============================================================================
# Development Configuration
# =============================================================================

# Environment
VITE_ENVIRONMENT=development

# Debug mode
VITE_DEBUG=true

# Hot reload
VITE_HMR=true
